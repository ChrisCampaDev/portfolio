---
import React from "@/components/icons/tools/react.astro";
import AstroIcon from "@/components/icons/tools/astro.astro";
import Css from "@/components/icons/tools/css.astro";
import Html from "@/components/icons/tools/html.astro";
import Node from "@/components/icons/tools/node.astro";
import Nextjs from "@/components/icons/tools/nexts.astro";
import Tailwind from "@/components/icons/tools/tailwindcss.astro";
import Ts from "@/components/icons/tools/ts.astro";
---

<div
	class="flex flex-wrap justify-center gap-3 sm:gap-5 p-2 sm:p-4 md:p-6 border bg-white/40 border-blue-950 dark:border-white dark:bg-stone-900 rounded-2xl"
	role="list"
	aria-label="Tecnologías y herramientas de desarrollo"
>
	<div
		class="size-12 sm:size-16 md:size-18 flex items-center justify-center"
		role="listitem"
	>
		<React class="w-8 h-8 sm:w-12 sm:h-12" aria-hidden="true" />
	</div>
	<div
		class="size-12 sm:size-16 md:size-18 flex items-center justify-center"
		role="listitem"
	>
		<AstroIcon class="w-8 h-8 sm:w-12 sm:h-12" aria-hidden="true" />
	</div>
	<div
		class="size-12 sm:size-16 md:size-18 flex items-center justify-center"
		role="listitem"
	>
		<Nextjs class="w-8 h-8 sm:w-12 sm:h-12" aria-hidden="true" />
	</div>
	<div
		class="size-12 sm:size-16 md:size-18 flex items-center justify-center"
		role="listitem"
	>
		<Css class="w-8 h-8 sm:w-12 sm:h-12" aria-hidden="true" />
	</div>
	<div
		class="size-12 sm:size-16 md:size-18 flex items-center justify-center"
		role="listitem"
	>
		<Html class="w-8 h-8 sm:w-12 sm:h-12" aria-hidden="true" />
	</div>
	<div
		class="size-12 sm:size-16 md:size-18 flex items-center justify-center"
		role="listitem"
	>
		<Node class="w-8 h-8 sm:w-12 sm:h-12" aria-hidden="true" />
	</div>
	<div
		class="size-12 sm:size-16 md:size-18 flex items-center justify-center"
		role="listitem"
	>
		<Tailwind class="w-8 h-8 sm:w-12 sm:h-12" aria-hidden="true" />
	</div>
	<div
		class="size-12 sm:size-16 md:size-18 flex items-center justify-center"
		role="listitem"
	>
		<Ts class="w-8 h-8 sm:w-12 sm:h-12" aria-hidden="true" />
	</div>
</div>