---
import { Badge } from "@/components/starwind/badge";
import { Button } from "@/components/starwind/button";
import { getTexts, getLocaleFromAstro } from "@/utils/i18n";
import projectsData from "@/content/projects.json";

interface Project {
	company: string;
	title: string;
	description: string;
	url: string;
	technologies: string[];
}

const texts = getTexts(Astro);
const locale = getLocaleFromAstro(Astro);
const allProjects: Project[] = projectsData[locale] || [];

const projectsWithUrl = allProjects.filter((p) => p.url && p.url.trim() !== "");
const projectsWithoutUrl = allProjects.filter(
	(p) => !p.url || p.url.trim() === "",
);
---

<section
	id="projects"
	aria-labelledby="projects-heading"
	class="py-16 px-4 scroll-mt-20"
>
	<div class="max-w-6xl mx-auto">
		<div class="text-center mb-12">
			<h2
				id="projects-heading"
				class="text-3xl font-bold text-gray-900 dark:text-white mb-2"
			>
				{texts.projects.title}
			</h2>
			<p class="text-gray-600 dark:text-gray-300">
				{texts.projects.subtitle}
			</p>
		</div>

		{
			projectsWithUrl.length > 0 && (
				<div class="mb-12">
					<h3 class="text-xl font-semibold text-gray-800 dark:text-gray-200 mb-6">
						{texts.projects.with_url}
					</h3>
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
						{projectsWithUrl.map((project) => (
							<article class="flex flex-col border dark:border-gray-200 border-blue-900 rounded-xl p-5 bg-neutral-primary-soft dark:bg-black/40 hover:shadow-lg transition-shadow">
								<div class="flex-1">
									<span class="text-xs font-semibold text-blue-600 dark:text-blue-400 uppercase tracking-wider">
										{project.company}
									</span>
									<h4 class="text-xl font-bold text-gray-900 dark:text-white mt-1 mb-2">
										{project.title}
									</h4>
									<p class="text-sm text-gray-600 dark:text-gray-300 mb-4">
										{project.description}
									</p>
								</div>
								<div class="flex flex-wrap gap-2 mb-4">
									{project.technologies.map((tech) => (
										<Badge variant="secondary" size="sm">
											{tech}
										</Badge>
									))}
								</div>
								<Button
									href={project.url}
									target="_blank"
									rel="noopener noreferrer"
									variant="primary"
									size="sm"
									class="mt-auto"
								>
									<svg
										class="w-4 h-4 mr-2"
										fill="none"
										stroke="currentColor"
										viewBox="0 0 24 24"
									>
										<path
											stroke-linecap="round"
											stroke-linejoin="round"
											stroke-width="2"
											d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
										/>
									</svg>
									{texts.projects.visit}
								</Button>
							</article>
						))}
					</div>
				</div>
			)
		}

		{
			projectsWithoutUrl.length > 0 && (
				<div>
					<h3 class="text-xl font-semibold text-gray-800 dark:text-gray-200 mb-6">
						{texts.projects.without_url}
					</h3>
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
						{projectsWithoutUrl.map((project) => (
							<article class="flex flex-col border dark:border-gray-200 border-blue-900 rounded-xl p-5 bg-neutral-primary-soft dark:bg-black/40">
								<span class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">
									{project.company}
								</span>
								<h4 class="text-xl font-bold text-gray-900 dark:text-white mt-1 mb-2">
									{project.title}
								</h4>
								<p class="text-sm text-gray-600 dark:text-gray-300 mb-4">
									{project.description}
								</p>
								<div class="flex flex-wrap gap-2 mt-auto">
									{project.technologies.map((tech) => (
										<Badge variant="outline" size="sm">
											{tech}
										</Badge>
									))}
								</div>
							</article>
						))}
					</div>
				</div>
			)
		}
	</div>
</section>
